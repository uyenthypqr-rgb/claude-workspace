{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:www.npmjs.com)",
      "Bash(npm -v)",
      "Bash(npm init *)",
      "Bash(npm install *)",
      "Bash(node node_modules/@supercorp/facebook-mcp/dist/index.js --facebookAppId YOUR_APP_ID --facebookAppSecret YOUR_APP_SECRET)",
      "Bash(kill %1)",
      "Bash(chmod +x *)",
      "mcp__claude_ai_Google_Drive__read_file_content",
      "mcp__claude_ai_Google_Drive__download_file_content",
      "Bash(python3 *)",
      "Bash(gh auth *)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(gh repo *)",
      "mcp__claude_ai_Google_Drive__create_file",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Skill(schedule)",
      "Skill(update-config)",
      "Skill(keybindings-help)"
    ]
  }
